# Copy this file to .env and fill in your values
# .env is git-ignored — never commit real credentials

# Environment selection: dev | staging | prod
TEST_ENV=dev

# Optional: override credentials for auth tests
SAINSBURYS_TEST_EMAIL=your_test_email@example.com
SAINSBURYS_TEST_PASSWORD=your_test_password

# Optional CI flags
CI=false
HEADLESS=true
